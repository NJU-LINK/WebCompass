# Dockerfile
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /testbed

# 基础工具 + Chrome 依赖
RUN apt-get update && apt-get install -y \
    vim \
    curl \
    wget \
    git \
    jq \
    build-essential \
    gnupg \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# 直接安装 Node.js 20（不用 nvm）
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && node -v \
    && npm -v

# 安装 Google Chrome
RUN wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor | tee /usr/share/keyrings/google-chrome.gpg > /dev/null \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list \
    && apt-get update \
    && apt-get install -y google-chrome-stable \
    && rm -rf /var/lib/apt/lists/*

RUN google-chrome --version

RUN npm config set registry https://npm.corp.kuaishou.com/ && \
    npm install -g chrome-devtools-mcp@0.12.1

COPY packages/ /tmp/packages/

RUN npm install -g /tmp/packages/anthropic-ai-claude-code-2.0.67.tgz \
    && CLI_PATH=$(npm root -g)/@anthropic-ai/claude-code/cli.js \
    && rm $CLI_PATH \
    && cp /tmp/packages/cli-2.0.67.js $CLI_PATH \
    && chmod +x $CLI_PATH \
    && rm -rf /tmp/packages

RUN mkdir -p ~/.claude && echo '{"env":{"DISABLE_AUTOUPDATER":1,"API_TIMEOUT_MS":"3000000","CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC":1}}' > ~/.claude/settings.json

RUN claude mcp add chrome-devtools npx chrome-devtools-mcp@0.12.1
